PORT=3333
HOST=127.0.0.1
APP_URL=http://$HOST:$PORT
NGROK_URL=<ngrok_url>
NODE_ENV=development
APP_KEY=<app_key>
DRIVE_DISK=local
SESSION_DRIVER=cookie
CACHE_VIEWS=false


GOOGLE_CLIENT_ID=<google_client_id>
GOOGLE_CLIENT_SECRET=<google_client_secret>
GOOGLE_API_KEY=<google_api_key>


DB_CONNECTION=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=<mysql_password>
MYSQL_DB_NAME=dashboard_myselfmonart


SHOPIFY_SHOP_URL=<shopify_shop_url>
SHOPIFY_API_VERSION='admin/api/2024-04'
SHOPIFY_ACCESS_TOKEN_SECRET=<shopify_access_token_secret>


FRONTEND_URL=<frontend_url>


ID_MERCHANT_CENTER=<id_merchant_center>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<smtp_username>
SMTP_PASSWORD=<smtp_password>
MAIL_SENDER=<mail_sender>
MAIL_RECIPIENT=<mail_recipient>


OPENAI_API_KEY=<openai_api_key>
OPENAI_MODEL=gpt-5


ANTHROPIC_API_KEY=<anthropic_api_key>
CLAUDE_MODEL=claude-sonnet-4-5


PINTEREST_CLIENT_ID=<pintarest_api_key>
PINTEREST_CLIENT_SECRET=<pintarest_secret_key>
PINTEREST_TEST_BOARD_ID=<pintarest_test_board_id>


CHROME_EXTENSION_ID=<chrome_extension_id>


DO_SPACES_KEY=<do_spaces_key>
DO_SPACES_SECRET=<do_spaces_secret>
DO_SPACES_REGION=<do_spaces_region>
DO_SPACES_BUCKET=<do_spaces_bucket>
DO_SPACES_ENDPOINT=<do_spaces_endpoint>
DO_SPACES_CDN_ENDPOINT=<do_spaces_cdn_endpoint>


SHOPIFY_STORE_DOMAIN=<shopify_store_domain>
SHOPIFY_ACCESS_TOKEN=<shopify_access_token>


INSTAGRAM_APP_ID=<instagram_app_id>
INSTAGRAM_APP_SECRET=<instagram_app_secret>


RESEND_API_KEY=<resend_api_key>
RESEND_FROM=<resend_from_email>


GEMINI_API_KEY=<gemini_api_key>


REPLICATE_API_TOKEN=<replicate_api_token>


CUSTOM_ART_MOCKUP_PSDS=<custom_art_mockup_psds>

# URL publique de la boutique (CORS du studio + liens des emails CustomArt).
# Ex : https://www.myselfmonart.com — REQUIS en prod pour le poster personnalisé.
STOREFRONT_URL=
# URL publique du backend (URLs de preview proxifiées renvoyées au studio).
BACKEND_URL=
# Moteur de rendu Photopea (mises en situation post-reveal).
# Ex : https://render.myselfmonart.com — vide = mockups désactivés (dégradation gracieuse).
RENDER_ENGINE_URL=
# Plafond de coût global quotidien du studio en euros (vide = 30).
# Atteint -> les nouveaux essais reçoivent « forte affluence » (code high_traffic).
CUSTOM_ART_DAILY_COST_CAP_EUR=
# Chaîne de providers de génération, entrées 'nom[:modèle]' séparées par des virgules.
# Vide = défaut bench M1 : gemini:gemini-3.1-flash-image,gemini:gemini-3-pro-image,gemini:gemini-2.5-flash-image
CUSTOM_ART_PROVIDER_CHAIN=
# Modèle du juge vision (vide = défaut du JudgeService).
CUSTOM_ART_JUDGE_MODEL=
# URL de l'image de référence scène/pose figée J1 (vide = référence embarquée).
CUSTOM_ART_SCENE_REF_URL=
# true en prod derrière Cloudflare : lit l'IP réelle dans CF-Connecting-IP pour les
# caps anti-abus (sinon, tous les visiteurs partagent l'IP du proxy et les caps
# par IP sont faussés). Ne l'activer que si l'origine n'accepte que le trafic Cloudflare.
TRUST_CF_CONNECTING_IP=

# Tests locaux M9 uniquement : saute l'upscale Replicate (payant) du fichier print.
# JAMAIS true en prod (le fichier serait interpolé au lieu d'être upscalé).
CUSTOM_ART_SKIP_UPSCALE=
# Modèle Replicate de l'upscale print ('owner/name' ou 'owner/name:version').
# Vide = défaut nightmareai/real-esrgan (Real-ESRGAN x4).
CUSTOM_ART_UPSCALE_MODEL=

# Tests locaux M10 + tests de charge M12 UNIQUEMENT : provider FACTICE — renvoie une
# image statique du bench (scripts/bench/results) sans aucun appel API payant, et le
# juge vision est court-circuité (verdict factice pass). IGNORÉ en production.
CUSTOM_ART_FAKE_PROVIDER=
# Dossier des images servies par le provider factice (chemin absolu, ou relatif à la
# racine du repo). Vide = scripts/bench/results/fiabilite-g31-v2/images.
CUSTOM_ART_FAKE_IMAGES_DIR=
