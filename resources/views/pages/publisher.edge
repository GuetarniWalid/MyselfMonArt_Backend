<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#FCFCFD">
<title>MyselfMonArt · Publisher</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/publisher/style.css?v=efa2d57ade">
</head>
<body>
<div class="app">

  <!-- En-tête -->
  <header class="topbar">
    <div class="brand">
      <span class="logo">◈</span>
      <span>MyselfMonArt <em>Publisher</em></span>
    </div>
    <div id="orientationBadge" class="badge hidden"></div>
  </header>

  <main class="content">

    <!-- 0. Produit à refaire (mode reimage uniquement — révélé par app.js) -->
    <section class="card hidden" id="productCard">
      <h2 class="card-title">1 · Produit à refaire</h2>
      <div class="field">
        <label>Produit existant</label>
        <div class="combo">
          <input type="text" id="productSearch" placeholder="Rechercher un produit…" autocomplete="off">
          <div id="productList" class="combo-list hidden"></div>
        </div>
        <div id="productChosen" class="chosen hidden"></div>
      </div>
      <!-- v2 : les images actuelles du produit vivent directement dans « Vos rendus »
           (supprimables/réordonnables) ; l'œuvre (image n°2, figée) dans la carte dédiée. -->
      <p id="productVideoNote" class="video-note hidden">🎬 La vidéo du produit sera conservée</p>
    </section>

    <!-- 1. Upload -->
    <section class="card" id="uploadCard">
      <h2 class="card-title">1 · Votre image</h2>
      <label id="dropzone" class="dropzone" for="fileInput">
        <input type="file" id="fileInput" accept="image/*" hidden>
        <div class="dz-inner" id="dzInner">
          <div class="dz-icon">⬆</div>
          <div class="dz-text"><b>Touchez pour choisir une image</b><span>ou glissez-la ici</span></div>
        </div>
        <div class="preview-wrap">
          <img id="sourcePreview" class="source-preview hidden" alt="aperçu">
          <div id="ratioOverlay" class="ratio-overlay hidden"></div>
        </div>
      </label>
      <p id="ratioWarning" class="ratio-warning hidden">⚠️ Format à ajuster — le cadre pointillé montre le format attendu.</p>
      <div class="upload-actions">
        <button id="changeImageBtn" class="ghost-btn hidden">Changer d'image</button>
        <button id="resizeBtn" class="accent-btn hidden">Retailler au bon format</button>
      </div>
    </section>

    <!-- 2. Paramètres -->
    <section class="card" id="paramsCard">
      <h2 class="card-title">2 · Produit & collection</h2>

      <div class="seg" id="productType">
        <button class="seg-btn active" data-type="toile">Toile</button>
        <button class="seg-btn" data-type="poster">Poster</button>
        <button class="seg-btn" data-type="tapisserie">Tapisserie</button>
      </div>

      <div class="field" id="collectionField">
        <label>Collection parente</label>
        <div class="combo">
          <input type="text" id="collectionSearch" placeholder="Rechercher une collection…" autocomplete="off">
          <div id="collectionList" class="combo-list hidden"></div>
        </div>
        <div id="collectionChosen" class="chosen hidden"></div>
      </div>
    </section>

    <!-- 3. Personnalisation studio (mode « poster personnalisé » uniquement — révélée par personalized.js).
         Builder de studio.config : preset -> formulaires guidés -> validation live (P2). -->
    <section class="card hidden" id="studioCard">
      <div class="card-head">
        <h2 class="card-title">3 · Personnalisation (studio)</h2>
        <span id="studioBadge" class="hint">—</span>
      </div>
      <!-- Aucune décision d'entrée : le parcours FAMILLE (photo → nom → prénoms → format) se charge
           automatiquement comme base — les étapes s'éditent/ajoutent/suppriment librement dessous.
           Le nom de code (productType) n'est PLUS saisi ici non plus : généré automatiquement à la
           publication (dérivé du titre IA, unicité garantie côté back). -->
      <div id="studioSteps" class="studio-steps"></div>
      <p id="studioEmpty" class="empty">Chargement du parcours client…</p>
      <button id="studioAddStep" class="ghost-btn hidden">＋ Ajouter une étape</button>
      <!-- Les traductions EN/DE/NL/ES sont générées automatiquement par le backend à la
           publication (depuis le français) : aucune UI de langue ici. -->
      <div id="studioValidation" class="studio-validation hidden"></div>
      <div id="studioPreviewWrap" class="studio-preview-wrap hidden">
        <div class="pp-head">
          <h3 class="card-subtitle">Aperçu du parcours client</h3>
        </div>
        <div id="studioPreviewStepper" class="studio-preview-stepper"></div>
        <div id="studioPreviewBody" class="studio-preview-body"></div>
      </div>
    </section>

    <!-- 4. Recette IA (mode « poster personnalisé » uniquement).
         Builder de studio.recipe + référence de style (P3). -->
    <section class="card hidden" id="recipeCard">
      <div class="card-head">
        <h2 class="card-title">4 · Recette IA</h2>
        <span id="recipeBadge" class="hint">—</span>
      </div>
      <div id="recipeForm" class="studio-step-body"></div>
      <p id="recipeEmpty" class="empty">La recette de génération se charge depuis le preset famille.</p>
      <div id="recipeValidation" class="studio-validation hidden"></div>
      <button id="recipeVerify" class="ghost-btn hidden">✓ Vérifier tout (serveur)</button>
      <div id="recipeVerifyResult" class="studio-validation hidden"></div>
    </section>

    <!-- 3. Mockups (catalogue Photopea + décors IA, regroupés par pièce) -->
    <section class="card" id="mockupsCard">
      <div class="card-head">
        <h2 class="card-title">3 · Mockups</h2>
        <span id="mockupsHint" class="hint">Ajoutez une image pour voir les mockups</span>
      </div>
      <p class="card-note">Appui long sur un mockup pour le mettre en favori ★. Vos favoris s'appliquent automatiquement dès que votre image est au bon format.</p>
      <div id="mockupGrid" class="mockup-grid"></div>
      <button id="decorBtn" class="ghost-btn decor-cta hidden">🎨 Créer un décor sur-mesure (IA)</button>
      <button id="mockupUploadBtn" class="ghost-btn decor-cta hidden">📥 Ajouter un mockup (photo nettoyée par IA)</button>
    </section>

    <!-- 4. Rendus -->
    <section class="card" id="resultsCard">
      <div class="card-head">
        <h2 class="card-title">4 · Vos rendus</h2>
        <span class="hint">Appui long puis glissez pour réorganiser</span>
      </div>
      <div id="resultsGrid" class="results-grid"></div>
      <p id="resultsEmpty" class="empty">Touchez un mockup ci-dessus pour générer votre premier rendu.</p>
      <!-- 2e rangée : jumeaux « passe-partout » (bords blancs) — posters uniquement -->
      <div id="ppSection" class="pp-section hidden">
        <div class="pp-head">
          <h3 class="card-subtitle">Passe-partout · bords blancs</h3>
          <span class="hint">Appui long pour réorganiser · touchez pour agrandir</span>
        </div>
        <div id="ppGrid" class="results-grid"></div>
      </div>
    </section>

  </main>

  <!-- Barre d'action fixe -->
  <footer class="actionbar">
    <div class="action-info" id="actionInfo">—</div>
    <button id="publishBtn" class="primary-btn" disabled>Publier l'œuvre</button>
  </footer>

  <!-- Overlay agrandissement -->
  <div id="lightbox" class="lightbox hidden"><img id="lightboxImg" alt=""><button class="lb-close">✕</button></div>

  <!-- Menu contextuel (appui long / clic droit) -->
  <div id="ctxMenu" class="ctx-menu hidden"></div>

  <!-- Toast -->
  <div id="toast" class="toast hidden"></div>

  <!-- Overlay de retaillage (preview avant/après GPT-image) -->
  <div id="resizeOverlay" class="resize-overlay hidden">
    <div class="resize-card">
      <h3 id="resizeTitle">Retaillage de l'œuvre</h3>
      <div class="resize-body">
        <div id="resizeLoading" class="resize-loading">
          <div class="progress-ring"></div>
          <p id="resizeLoadingMsg">Génération de l'aperçu…</p>
        </div>
        <div id="resizeCompare" class="resize-compare hidden">
          <div class="rc-col"><span>Avant</span><img id="resizeBefore" alt="avant"></div>
          <div class="rc-col"><span>Après</span><img id="resizeAfter" alt="après"></div>
        </div>
      </div>
      <div id="resizeActions" class="resize-actions hidden">
        <button id="resizeValidate" class="primary-btn">Valider (haute qualité)</button>
        <button id="resizeRetry" class="ghost-btn">Relancer</button>
        <button id="resizeCancel" class="ghost-btn">Annuler</button>
      </div>
      <div id="resizeFinal" class="resize-actions hidden">
        <button id="resizeClose" class="primary-btn">Parfait, utiliser cette image</button>
        <button id="resizeRegenHigh" class="ghost-btn">Régénérer en haute qualité</button>
      </div>
    </div>
  </div>

  <!-- Overlay de génération de décor IA -->
  <div id="decorOverlay" class="resize-overlay hidden">
    <div class="resize-card">
      <h3>Décor sur-mesure (IA)</h3>
      <div class="resize-body">
        <select id="decorRoom" class="decor-vibe">
          <option value="">Pièce : Automatique (variée)</option>
          <option value="living room">Salon</option>
          <option value="bedroom">Chambre</option>
          <option value="kitchen">Cuisine</option>
          <option value="dining room">Salle à manger</option>
          <option value="home office">Bureau</option>
          <option value="entryway">Entrée</option>
          <option value="bathroom">Salle de bain</option>
          <option value="reading nook">Coin lecture</option>
          <option value="studio">Atelier</option>
        </select>
        <input id="decorVibe" class="decor-vibe" type="text" maxlength="200" placeholder="Style libre (optionnel) : ex. chambre scandinave, tons terracotta, vinyle vintage…">
        <div id="decorLoading" class="resize-loading hidden">
          <div class="progress-ring"></div>
          <p id="decorLoadingMsg">Génération du décor…</p>
        </div>
        <div id="decorResult" class="decor-result hidden">
          <img id="decorImg" alt="décor généré">
        </div>
      </div>
      <div id="decorStartActions" class="resize-actions">
        <button id="decorGenerate" class="primary-btn">Générer le décor</button>
        <button id="decorCancel" class="ghost-btn">Annuler</button>
      </div>
      <div id="decorActions" class="resize-actions hidden">
        <button id="decorValidate" class="primary-btn">Valider ce décor</button>
        <button id="decorSave" class="ghost-btn">★ Enregistrer ce décor</button>
        <button id="decorRegen" class="ghost-btn">Régénérer</button>
        <button id="decorClose" class="ghost-btn">Fermer</button>
      </div>
    </div>
  </div>

  <!-- Overlay d'insertion de l'œuvre dans le décor (étape 2) -->
  <div id="insertOverlay" class="resize-overlay hidden">
    <div class="resize-card">
      <h3>Insérer l'œuvre dans le décor</h3>
      <div class="resize-body">
        <label class="decor-fidelity"><input type="checkbox" id="insertHighFidelity"> Haute fidélité (mieux pour le texte ; plus lent et plus cher)</label>
        <div id="insertLoading" class="resize-loading hidden">
          <div class="progress-ring"></div>
          <p id="insertLoadingMsg">Insertion de votre œuvre…</p>
        </div>
        <div id="insertResult" class="decor-result hidden">
          <img id="insertImg" alt="rendu final">
        </div>
      </div>
      <div id="insertStartActions" class="resize-actions">
        <button id="insertGenerate" class="primary-btn">Insérer mon œuvre</button>
        <button id="insertCancel" class="ghost-btn">Annuler</button>
      </div>
      <div id="insertActions" class="resize-actions hidden">
        <button id="insertValidate" class="primary-btn">Valider ce rendu</button>
        <button id="insertRegen" class="ghost-btn">Régénérer l'insertion</button>
        <button id="insertClose" class="ghost-btn">Fermer</button>
      </div>
    </div>
  </div>

  <!-- Overlay d'ajout de mockup (photo importée, nettoyée par IA) -->
  <div id="cleanOverlay" class="resize-overlay hidden">
    <div class="resize-card">
      <h3>Ajouter un mockup</h3>
      <div class="resize-body">
        <p class="card-note">Importez une photo de mise en situation — même avec textes, logos ou une œuvre déjà dans le cadre. L'IA retire tous les marquages, vide le support (gris neutre) au format de votre œuvre et le convertit au type produit choisi.</p>
        <input type="file" id="cleanFile" accept="image/*" class="decor-vibe">
        <div id="cleanSrcWrap" class="decor-result hidden"><img id="cleanSrcImg" alt="photo importée"></div>
        <div id="cleanLoading" class="resize-loading hidden">
          <div class="progress-ring"></div>
          <p id="cleanLoadingMsg">Nettoyage du mockup…</p>
        </div>
        <div id="cleanResult" class="decor-result hidden"><img id="cleanImg" alt="mockup nettoyé"></div>
      </div>
      <div id="cleanStartActions" class="resize-actions">
        <button id="cleanGenerate" class="primary-btn" disabled>Nettoyer le mockup</button>
        <button id="cleanCancel" class="ghost-btn">Annuler</button>
      </div>
      <div id="cleanActions" class="resize-actions hidden">
        <div class="section-inline">
          <label for="cleanSection">Ranger dans :</label>
          <select id="cleanSection" class="decor-vibe"></select>
          <input id="cleanSectionNew" class="decor-vibe hidden" type="text" maxlength="40" placeholder="Nom de la nouvelle section">
        </div>
        <button id="cleanValidate" class="primary-btn">Utiliser ce mockup</button>
        <button id="cleanSave" class="ghost-btn">★ Enregistrer ce mockup</button>
        <button id="cleanRegen" class="ghost-btn">Renettoyer</button>
        <button id="cleanClose" class="ghost-btn">Fermer</button>
      </div>
    </div>
  </div>

  <!-- Overlay « Ranger dans une section » (appui long sur un mockup) -->
  <div id="sectionOverlay" class="resize-overlay hidden">
    <div class="resize-card">
      <h3>Ranger dans une section</h3>
      <p id="sectionPickerName" class="card-note"></p>
      <div id="sectionList" class="section-list"></div>
      <div class="section-new">
        <input id="sectionNewInput" class="decor-vibe" type="text" maxlength="40" placeholder="Nouvelle section… (ex. Chambre)">
        <button id="sectionNewAdd" class="ghost-btn">Créer et ranger ici</button>
      </div>
      <div class="resize-actions">
        <button id="sectionCancel" class="ghost-btn">Annuler</button>
      </div>
    </div>
  </div>

  <!-- Overlay d'édition d'une étape studio (mode personalized) — corps construit par personalized.js -->
  <div id="studioStepOverlay" class="resize-overlay hidden">
    <div class="resize-card">
      <h3 id="studioStepTitle">Modifier l'étape</h3>
      <div id="studioStepBody" class="studio-step-body"></div>
      <div class="resize-actions">
        <button id="studioStepSave" class="primary-btn">Enregistrer</button>
        <button id="studioStepCancel" class="ghost-btn">Annuler</button>
      </div>
    </div>
  </div>

  <!-- Overlay « Ajouter une étape » : choix du type (mode personalized) -->
  <div id="studioTypeOverlay" class="resize-overlay hidden">
    <div class="resize-card">
      <h3>Ajouter une étape</h3>
      <div id="studioTypeList" class="section-list"></div>
      <div class="resize-actions">
        <button id="studioTypeCancel" class="ghost-btn">Annuler</button>
      </div>
    </div>
  </div>

  <!-- Overlay de progression (publication) -->
  <div id="progress" class="progress-overlay hidden">
    <div class="progress-card">
      <div id="progressSpinner" class="progress-ring"></div>
      <div id="progressIcon" class="progress-icon hidden"></div>
      <h3 id="progressTitle">Publication en cours…</h3>
      <p id="progressMsg">Préparation des images…</p>
      <button id="progressClose" class="primary-btn hidden">Fermer</button>
      <a id="progressLink" class="ghost-btn hidden" target="_blank" rel="noopener">Voir le produit</a>
    </div>
  </div>
</div>
<!-- Config injectée par le backend :
     - renderBase : URL du moteur de rendu (PC, via tunnel Cloudflare) — variable d'env RENDER_ENGINE_URL
     - apiBase    : vide => même origine (ce backend sert collections + publish)
     - mode       : '' = create (publication classique), 'reimage' = refaire les images d'un produit,
                    'personalized' = créer un poster personnalisé (builder studio.config/recipe) -->
<script>
  window.PUBLISHER_CONFIG = {
    renderBase: {{{ JSON.stringify(renderBase || '') }}},
    apiBase: '',
    mode: {{{ JSON.stringify(mode || '') }}}
  };
</script>
<script src="/publisher/app.js?v=d9cb8f3e02"></script>
<script src="/publisher/lib/validate-studio-config.js?v=0d31f38dda"></script>
<script src="/publisher/personalized.js?v=34a01e117e"></script>
</body>
</html>
