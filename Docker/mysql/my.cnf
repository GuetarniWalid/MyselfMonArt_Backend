[mysqld]
# Tuning pour VPS 1.9 GB RAM — DB dashboard_myselfmonart
# Objectif: faire passer MySQL de ~550 MB RSS à ~150 MB RSS
# Monté dans le conteneur via /etc/mysql/conf.d/ (inclus par !includedir)

# --- Gain principal: ~400 MB ---
performance_schema = OFF

# --- Buffer InnoDB: 64M suffit largement pour une petite DB ---
innodb_buffer_pool_size = 64M
innodb_buffer_pool_instances = 1
innodb_log_file_size = 32M
innodb_redo_log_capacity = 64M

# --- Bornage des connexions (protection) ---
max_connections = 30

# --- Tables temporaires: défaut MySQL 8 = 1 GB !!! ---
temptable_max_ram = 64M
tmp_table_size = 8M
max_heap_table_size = 8M

# --- Caches divers ---
table_open_cache = 400
thread_cache_size = 8
thread_stack = 256K

# --- Binlog: rétention raccourcie (gain disque) ---
binlog_expire_logs_seconds = 259200
